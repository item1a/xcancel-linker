{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "xcancel-linker",
  "server": {
    "dir": "dist/server",
    "entry": "index.js"
  },
  "permissions": {
    "reddit": true,
    "redis": true,
    "http": {
      "enable": true,
      "domains": ["api.fxtwitter.com"]
    }
  },
  "triggers": {
    "onCommentSubmit": "/internal/on-comment-submit",
    "onPostSubmit": "/internal/on-post-submit"
  },
  "scripts": {
    "dev": "node --experimental-strip-types ./tools/build.ts --watch",
    "build": "node --experimental-strip-types ./tools/build.ts --minify"
  },
  "dev": {
    "subreddit": "xcancel_linker_dev"
  },
  "settings": {
    "subreddit": {
      "enrichTweetPreviews": {
        "type": "boolean",
        "label": "Include tweet previews in replies",
        "helpText": "When on, replies include the tweet author and a short preview of the tweet text alongside the xcancel mirror. Turn off to get bare mirror URLs only.",
        "defaultValue": true
      }
    }
  }
}